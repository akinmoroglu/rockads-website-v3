NUXT_PUBLIC_APP_URL=https://stage.rockads.com/
NUXT_PUBLIC_PANEL_AUTO_LOGIN_URL=https://stage-panel.rockads.com/login
NUXT_PUBLIC_GTM_KEY=GTM-T86XS32

# Public base URL for auth API routes (no trailing slash). See app/lib/auth-api-paths.ts for paths.
NUXT_PUBLIC_AUTH_API_BASE=https://api-stage.rockads.com/

# Optional: send cookies on auth requests (e.g. refresh cookie alongside JWT).
# NUXT_PUBLIC_AUTH_WITH_CREDENTIALS=true

# Cloudflare Turnstile — get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public (rendered in the browser widget).
NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Optional: bypass Turnstile on staging/test environments where the backend
# accepts a fixed dummy token instead of verifying with Cloudflare.
# When set, the Turnstile widget is hidden and this value is sent as the captcha token.
NUXT_PUBLIC_CAPTCHA_DUMMY_TOKEN=XXXX.DUMMY.TOKEN.XXXX